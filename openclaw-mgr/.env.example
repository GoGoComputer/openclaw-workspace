# =============================================================================
# .env.example — openclaw-mgr 환경 설정 예시
# ./openclaw 첫 실행 시 이 파일로 .env 가 자동 생성됩니다. 수동 cp 불필요.
# 이 파일은 안전하게 커밋해도 됩니다. .env 는 절대 커밋하지 마세요!
#
# ⚠  이 레포는 "연결·설정·자동화" 전담입니다.
#    OpenClaw 본체 / Ollama / Docker 는 각 공식 사이트에서 받으세요.
#    이 파일을 통해 경로·포트·보안만 제어합니다.
# =============================================================================

# ── OpenClaw 저장소 (필수) ──────────────────────────────────────────────────
# OpenClaw 공식 GitHub 저장소 URL (공식: https://github.com/openclaw/openclaw)
OPENCLAW_REPO="https://github.com/openclaw/openclaw.git"

# 로컬에 clone 할 경로 (기본 ~/DEV/openclaw)
OPENCLAW_DIR="$HOME/DEV/openclaw"

# (선택) 특정 커밋에 고정 — 공급망 보안. 비우면 기본 브랜치 최신.
OPENCLAW_PIN_COMMIT=""

# ── 에이전트 파일 경로 ────────────────────────────────────────────────────────
# 에이전트가 만드는 파일이 이 폴더에 저장됩니다 (Docker 볼륨 마운트).
# ~/DEV/openclawAgent 를 Finder 에서 바로 확인할 수 있습니다.
# ⚠ 로컬 시스템에는 아무것도 직접 설치되지 않습니다 — 모두 Docker 컨테이너 안.
OPENCLAW_WORKSPACE_DIR="$HOME/DEV/openclawAgent"

# OpenClaw 설정·토큰·세션 저장 위치 (숨김 폴더 — 직접 편집 불필요)
OPENCLAW_CONFIG_DIR="$HOME/.openclaw"

# ── 네트워크 ─────────────────────────────────────────────────────────────────
# 게이트웨이 포트 (로컬호스트 전용 — LAN 에 절대 노출 안 됨)
OPENCLAW_GATEWAY_PORT="18789"
OPENCLAW_BRIDGE_PORT="18790"

# (참고) 컨테이너의 외부 인터넷 차단은 .env 가 아니라
# `./openclaw network isolated|online` 으로 토글합니다.
# 기본값은 'isolated' (최고 보안 — 외부 통신 완전 차단).

# ── Ollama (로컬 LLM) ────────────────────────────────────────────────────────
# Ollama 실행 방식:
#   host   = macOS 에 직접 설치 (ollama.com 공식 앱, 추천 — Apple Silicon GPU 활용)
#   docker = Docker 컨테이너로 실행 (compose.ollama.yml 포함 필요, GPU 미활용)
OLLAMA_MODE="host"

# 자동으로 pull 받을 모델 (콤마 구분). M5 Pro 24GB 권장값:
#   - qwen2.5-coder:7b   코딩 추천, ~4.7GB (Apple Silicon Neural Engine 최적화)
#   - llama3.2:3b        경량 범용, ~2.0GB  (빠른 응답)
#   - llama3.1:8b        고품질 범용, ~4.9GB
# ⚠ 13B 이상은 24GB 에서 메모리 부족 위험 (macOS 공유 메모리 구조상 8-9B 권장)
OLLAMA_MODELS="qwen2.5-coder:7b"

# ── default 모델 강제 lock (v0.2.23+) ───────────────────────────────────────
# `./openclaw setup` 의 자동 최적화 함수가 size 만 보고 더 작은 모델로 바꾸지 못하게,
# 사용자가 명시적으로 고른 모델을 영구 lock 합니다. 비워 두면 자동 정책:
#   1) 현재 models[0] 가 tools-capable 이면 그대로 둠
#   2) 아니면 가장 작은 tools-capable 모델로 swap
# 추천 값:
#   gemma4:latest                       8.9GB · vision+audio+tools+thinking, instruction-following 가장 좋음
#   qwen2.5:7b-instruct                 4.7GB · tools, 한국어/영어 모두 강함
#   qwen2.5:3b-instruct                 1.8GB · tools, 가장 가볍지만 instruction-following 약함
#   llama3.1:8b-instruct-q4_K_M         4.6GB · tools, q4 양자화로 응답 느림
OPENCLAW_FORCE_DEFAULT_MODEL=""

# ── 컨테이너 리소스 한도 (보안/안정성) ────────────────────────────────────────
# M5 Pro 24GB 기준: 에이전트 컨테이너에 8GB / 8 CPU 코어 제한
OPENCLAW_MEM_LIMIT="8g"
OPENCLAW_CPUS="8"

# ── 샌드박스 (기본 ON — 이 프로젝트의 핵심 보안 레이어) ──────────────────
# 1 = 에이전트가 코드 실행 시 별도 격리 컨테이너 사용 (권장 — "Docker 샌드박스 설치" 의 동의어)
# 0 = 비활성 — 개인 일상용으로만, 프로덕션 · 민감 데이터 · 신뢰 안 되는 모델 실험에서는 절대 비추
OPENCLAW_SANDBOX="1"

# ── 자동 업데이트 ────────────────────────────────────────────────────────────
SCHEDULE_TIME="03:00"

# ── 백업 ────────────────────────────────────────────────────────────────────
BACKUP_DIR="$HOME/openclaw-backups"
BACKUP_KEEP="7"
BACKUP_ENCRYPT="1"

