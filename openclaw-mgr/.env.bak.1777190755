# =============================================================================
# .env.example — openclaw-mgr 환경 설정 예시
# ./openclaw 첫 실행 시 이 파일로 .env 가 자동 생성됩니다. 수동 cp 불필요.
# 이 파일은 안전하게 커밋해도 됩니다. .env 는 절대 커밋하지 마세요!
# =============================================================================

# ── OpenClaw 저장소 (필수) ──────────────────────────────────────────────────
# OpenClaw 공식 GitHub 저장소 URL.
OPENCLAW_REPO="https://github.com/openclaw/openclaw.git"

# 로컬에 clone 할 경로 (기본 ~/openclaw)
OPENCLAW_DIR="$HOME/openclaw"

# (선택) 특정 커밋에 고정 — 공급망 보안. 비우면 기본 브랜치 최신.
OPENCLAW_PIN_COMMIT=""

# ── 네트워크 ─────────────────────────────────────────────────────────────────
# 외부 노출 포트. 항상 127.0.0.1 에만 바인딩됩니다 (LAN 노출 안 함).
OPENCLAW_PORT="8000"

# (참고) 컨테이너의 외부 인터넷 차단은 .env 가 아니라
# `./openclaw network isolated|online` 으로 토글합니다.
# 기본값은 'isolated' (최고 보안 — 외부 통신 완전 차단).

# ── Ollama (로컬 LLM) ────────────────────────────────────────────────────────
# 1=설치하고 컨테이너에서 host.docker.internal:11434 로 연결 / 0=비활성
ENABLE_OLLAMA="1"

# 자동으로 pull 받을 모델 (콤마 구분). 24GB RAM 권장값:
#   - qwen2.5-coder:7b  (코딩 추천, ~4.7GB)
#   - llama3.1:8b       (범용, ~4.9GB)
# 13B 이상은 메모리 부족 경고가 뜹니다.
OLLAMA_MODELS="qwen2.5-coder:7b"

# ── 컨테이너 리소스 한도 (보안/안정성) ────────────────────────────────────────
OPENCLAW_MEM_LIMIT="8g"
OPENCLAW_CPUS="8"

# ── 자동 업데이트 ────────────────────────────────────────────────────────────
# `./openclaw schedule enable` 시 매일 이 시각에 update 실행 (HH:MM 24h)
SCHEDULE_TIME="03:00"

# ── 백업 ────────────────────────────────────────────────────────────────────
# 백업 저장 위치
BACKUP_DIR="$HOME/openclaw-backups"

# 보관할 백업 개수 (오래된 것부터 자동 삭제)
BACKUP_KEEP="7"

# 백업의 .env 부분을 GPG 대칭키로 암호화 (강력 권장)
BACKUP_ENCRYPT="1"
